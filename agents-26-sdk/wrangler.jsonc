{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "xampler-agents-26-sdk",
  "main": "src/entry.py",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["python_workers", "python_dedicated_snapshot"],
  "limits": { "cpu_ms": 60000 },
  "durable_objects": {
    "bindings": [
      { "name": "AGENT", "class_name": "AgentDurableObject" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["AgentDurableObject"] }
  ],
  "ai": { "binding": "AI" }
}
