{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "xampler-websockets-14-stream-consumer",
  "main": "src/entry.py",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["python_workers"],
  "durable_objects": {
    "bindings": [{"name": "CONSUMER", "class_name": "StreamConsumer"}]
  },
  "migrations": [{"tag": "v1", "new_sqlite_classes": ["StreamConsumer"]}]
}
