{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "xampler-storage-data-r2-object-storage",
  "main": "src/entry.py",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["python_workers"],
  "workers_dev": true,
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "xampler-r2-demo"
    }
  ]
}
