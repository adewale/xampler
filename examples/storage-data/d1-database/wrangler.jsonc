{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "xampler-storage-data-d1-database",
  "main": "src/entry.py",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["python_workers"],
  "d1_databases": [{"binding": "DB", "database_name": "xampler-d1", "database_id": "REPLACE_WITH_D1_DATABASE_ID"}]
}
