{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "xampler-full-apps-mini-wiki",
  "main": "src/entry.py",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["python_workers"],
  "assets": {"directory": "./assets"},
  "d1_databases": [
    {"binding": "DB", "database_name": "xampler-mini-wiki", "database_id": "REPLACE_WITH_D1_DATABASE_ID"}
  ]
}
